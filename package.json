{
    "name": "sigx-devtools-monorepo",
    "version": "0.0.1",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "description": "SignalX DevTools — page-side plugin, Chrome extension, standalone inspector",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "pnpm --filter @sigx/devtools run build && pnpm --filter sigx-devtools-extension run build && pnpm --filter sigx-devtools-inspector run build",
        "build:plugin": "pnpm --filter @sigx/devtools run build",
        "build:extension": "pnpm --filter sigx-devtools-extension run build",
        "build:inspector": "pnpm --filter sigx-devtools-inspector run build",
        "pack:extension": "pnpm --filter sigx-devtools-extension run pack",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsgo --noEmit && pnpm --filter sigx-devtools-extension run typecheck && pnpm --filter sigx-devtools-inspector run typecheck",
        "lint": "oxlint packages/devtools/src",
        "lint:fix": "oxlint --fix packages/devtools/src",
        "publish:dry": "node scripts/publish.js --dry-run",
        "publish:all": "node scripts/publish.js",
        "publish:beta": "node scripts/publish.js --tag beta",
        "version:set": "node scripts/bump-version.js",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major",
        "clean": "node -e \"const fs=require('fs'),p=require('path');const rm=x=>fs.rmSync(x,{recursive:true,force:true});for(const d of fs.readdirSync('packages')){rm(p.join('packages',d,'dist'));rm(p.join('packages',d,'dist-panel'));rm(p.join('packages',d,'dist-server'));rm(p.join('packages',d,'node_modules'));}rm('node_modules');rm('pnpm-lock.yaml');\""
    },
    "devDependencies": {
        "@typescript/native-preview": "7.0.0-dev.20260507.1",
        "@vitest/coverage-v8": "^4.1.5",
        "happy-dom": "^20.9.0",
        "oxlint": "^1.63.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.11",
        "vitest": "^4.1.5"
    },
    "keywords": [
        "SignalX",
        "sigx",
        "devtools",
        "debugging",
        "inspector",
        "chrome-extension"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/devtools.git"
    },
    "homepage": "https://github.com/signalxjs/devtools",
    "bugs": {
        "url": "https://github.com/signalxjs/devtools/issues"
    }
}
