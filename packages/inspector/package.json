{
    "name": "sigx-devtools-inspector",
    "version": "0.0.1",
    "private": true,
    "description": "Standalone HTTP+WS inspector for SignalX apps that don't run in a browser (Lynx, terminal, etc.)",
    "type": "module",
    "bin": {
        "sigx-devtools-inspector": "./bin/sigx-devtools-inspector.js"
    },
    "scripts": {
        "build:panel": "vite build",
        "build:server": "tsc -p tsconfig.server.json",
        "build": "pnpm build:panel && pnpm build:server",
        "start": "node ./bin/sigx-devtools-inspector.js",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@sigx/devtools": "workspace:^",
        "@sigx/reactivity": "^0.5.0",
        "@sigx/runtime-core": "^0.5.0",
        "sigx": "^0.5.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/ws": "^8.5.13",
        "typescript": "^5.9.0",
        "vite": "^8.0.11"
    }
}
