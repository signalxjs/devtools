{
    "name": "sigx-devtools-extension",
    "version": "0.0.1",
    "private": true,
    "description": "Chrome DevTools extension for SignalX",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch --mode development",
        "pack": "vite build && node scripts/pack.mjs",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@sigx/devtools": "workspace:^",
        "@sigx/reactivity": "^0.5.0",
        "@sigx/runtime-core": "^0.5.0",
        "sigx": "^0.5.0"
    },
    "devDependencies": {
        "@types/chrome": "^0.0.270",
        "esbuild": "^0.28.0",
        "typescript": "^5.9.0",
        "vite": "^8.0.11"
    }
}
